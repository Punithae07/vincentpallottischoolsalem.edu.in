        <span class="material-symbols-outlined">expand_less</span>
    </button>

    <script>
        // Mobile Menu Functionality
        const mobileMenuTrigger = document.getElementById('mobile-menu-trigger');
        const mobileMenuModal = document.getElementById('mobile-menu-modal');
        const closeMobileMenu = document.getElementById('close-mobile-menu');

        // Open mobile menu
        if (mobileMenuTrigger) {
            mobileMenuTrigger.addEventListener('click', function(e) {
                e.stopPropagation();
                mobileMenuModal.classList.add('active');
            });
        }

        // Close mobile menu
        if (closeMobileMenu) {
            closeMobileMenu.addEventListener('click', function(e) {
                e.stopPropagation();
                mobileMenuModal.classList.remove('active');
            });
        }

        // Close menu when clicking on the modal background
        if (mobileMenuModal) {
            mobileMenuModal.addEventListener('click', function(e) {
                if (e.target === mobileMenuModal) {
                    mobileMenuModal.classList.remove('active');
                }
            });

            // Close menu when clicking on a link
            const menuLinks = mobileMenuModal.querySelectorAll('a');
            menuLinks.forEach(link => {
                link.addEventListener('click', function() {
                    mobileMenuModal.classList.remove('active');
                });
            });
        }

        // Prevent modal close when clicking on content
        const mobileMenuContent = document.querySelector('.mobile-menu-content');
        if (mobileMenuContent) {
            mobileMenuContent.addEventListener('click', function(e) {
                e.stopPropagation();
            });
        }

        // Admission button functionality
        const admissionBtn = document.getElementById('admission-btn');
        if (admissionBtn) {
            admissionBtn.addEventListener('click', function() {
                // Close the mobile menu first
                mobileMenuModal.classList.remove('active');
                // You can add your admission form or redirect here
                console.log('Admission button clicked - Add your admission form or redirect here');
                // Example: window.location.href = '/admission';
            });
        }

        // Scroll to top button functionality
        const scrollTopBtn = document.querySelector('button.fixed');
        if (scrollTopBtn) {
            scrollTopBtn.addEventListener('click', function() {
                window.scrollTo({
                    top: 0,
                    behavior: 'smooth'
                });
            });

            // Show/hide scroll button based on scroll position
            window.addEventListener('scroll', function() {
                if (window.pageYOffset > 300) {
                    scrollTopBtn.style.opacity = '1';
                    scrollTopBtn.style.pointerEvents = 'auto';
                } else {
                    scrollTopBtn.style.opacity = '0.3';
                    scrollTopBtn.style.pointerEvents = 'none';
                }
            });
        }
    </script>
</body>

</html>