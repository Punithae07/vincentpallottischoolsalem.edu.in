<!DOCTYPE html>

<html class="scroll-smooth" lang="en">

<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>AcademicPrestige | Modern Excellence in Education</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link
        href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;600;700;800&amp;family=Inter:wght@400;600&amp;display=swap"
        rel="stylesheet" />
    <link
        href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap"
        rel="stylesheet" />
    <script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    "colors": {
                        "on-primary": "#ffffff",
                        "primary-container": "#063b56",
                        "on-primary-fixed-variant": "#1e4b66",
                        "error": "#ba1a1a",
                        "primary": "#002538",
                        "on-secondary-container": "#00751f",
                        "surface": "#f9f9ff",
                        "background": "#f9f9ff",
                        "surface-variant": "#d8e3fb",
                        "tertiary-container": "#003966",
                        "surface-tint": "#38637f",
                        "on-surface-variant": "#41474d",
                        "on-secondary": "#ffffff",
                        "tertiary-fixed": "#d2e4ff",
                        "surface-dim": "#cfdaf2",
                        "surface-bright": "#f9f9ff",
                        "tertiary": "#002342",
                        "on-tertiary-fixed-variant": "#004880",
                        "inverse-surface": "#263143",
                        "surface-container-lowest": "#ffffff",
                        "on-primary-container": "#7ca5c5",
                        "on-tertiary-fixed": "#001c37",
                        "on-tertiary-container": "#67a4ec",
                        "secondary-container": "#71ff79",
                        "secondary": "#006e1d",
                        "secondary-fixed-dim": "#53e160",
                        "on-secondary-fixed": "#002204",
                        "on-primary-fixed": "#001e2f",
                        "surface-container": "#e7eeff",
                        "on-error": "#ffffff",
                        "primary-fixed": "#c9e6ff",
                        "outline": "#72787e",
                        "primary-fixed-dim": "#a1cced",
                        "on-background": "#111c2d",
                        "on-secondary-fixed-variant": "#005314",
                        "inverse-primary": "#a1cced",
                        "tertiary-fixed-dim": "#a1c9ff",
                        "surface-container-high": "#dee8ff",
                        "on-tertiary": "#ffffff",
                        "error-container": "#ffdad6",
                        "outline-variant": "#c1c7ce",
                        "inverse-on-surface": "#ecf1ff",
                        "surface-container-highest": "#d8e3fb",
                        "surface-container-low": "#f0f3ff",
                        "secondary-fixed": "#71ff79",
                        "on-surface": "#111c2d",
                        "on-error-container": "#93000a"
                    },
                    "borderRadius": {
                        "DEFAULT": "0.25rem",
                        "lg": "0.5rem",
                        "xl": "0.75rem",
                        "full": "9999px"
                    },
                    "spacing": {
                        "section-padding": "80px",
                        "margin-mobile": "16px",
                        "stack-sm": "8px",
                        "stack-md": "16px",
                        "stack-lg": "32px",
                        "gutter": "24px",
                        "container-max": "1280px"
                    },
                    "fontFamily": {
                        "h2": ["Plus Jakarta Sans"],
                        "label-sm": ["Inter"],
                        "h1": ["Plus Jakarta Sans"],
                        "body-lg": ["Inter"],
                        "h3": ["Plus Jakarta Sans"],
                        "body-md": ["Inter"]
                    },
                    "fontSize": {
                        "h2": ["36px", { "lineHeight": "1.3", "fontWeight": "700" }],
                        "label-sm": ["14px", { "lineHeight": "1.2", "letterSpacing": "0.05em", "fontWeight": "600" }],
                        "h1": ["48px", { "lineHeight": "1.2", "letterSpacing": "-0.02em", "fontWeight": "700" }],
                        "body-lg": ["18px", { "lineHeight": "1.6", "fontWeight": "400" }],
                        "h3": ["24px", { "lineHeight": "1.4", "fontWeight": "600" }],
                        "body-md": ["16px", { "lineHeight": "1.6", "fontWeight": "400" }]
                    }
                },
            },
        }
    </script>
    <style>
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }

        .blob-bg {
            position: absolute;
            z-index: -1;
            filter: blur(80px);
            border-radius: 50%;
            opacity: 0.15;
        }

        .notice-card {
            border: 1px solid rgba(255, 255, 255, 0.2);
            background: rgba(255, 255, 255, 0.05);
        }

        .circular-mask {
            clip-path: circle(50% at 50% 50%);
        }

        .footer-curve {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            overflow: hidden;
            line-height: 0;
            transform: translateY(-99%);
        }

        .footer-curve svg {
            position: relative;
            display: block;
            width: calc(100% + 1.3px);
            height: 80px;
        }

        .footer-curve .shape-fill {
            fill: #002538;
        }

        @keyframes gradient-bg {
            0% {
                background-position: 0% 50%;
            }

            50% {
                background-position: 100% 50%;
            }

            100% {
                background-position: 0% 50%;
            }
        }

        .animate-gradient {
            background: linear-gradient(-45deg, #002538, #063B56, #004880, #002538);
            background-size: 400% 400%;
            animation: gradient-bg 15s ease infinite;
        }

        /* Dropdown Styles */
        .dropdown-menu {
            position: absolute;
            top: 100%;
            left: 0;
            min-w-max;
            background: white;
            border-radius: 8px;
            shadow: 0 4px 12px rgba(0, 0, 0, 0.15);
            padding: 8px 0;
            margin-top: 12px;
            opacity: 0;
            visibility: hidden;
            transform: translateY(-10px);
            transition: all 0.3s ease;
            z-index: 1000;
        }

        .dropdown-item:hover .dropdown-menu {
            opacity: 1;
            visibility: visible;
            transform: translateY(0);
        }

        .dropdown-menu a {
            display: block;
            padding: 10px 20px;
            color: #002538;
            text-decoration: none;
            font-size: 12px;
            font-weight: 600;
            transition: all 0.2s ease;
            border-left: 3px solid transparent;
        }

        .dropdown-menu a:hover {
            background: #f5f5f5;
            color: #006e1d;
            border-left-color: #006e1d;
            padding-left: 25px;
        }

        /* Mobile Menu Modal */
        .mobile-menu-modal {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: rgba(0, 0, 0, 0.5);
            display: none;
            opacity: 0;
            transition: opacity 0.3s ease;
            z-index: 200;
        }

        .mobile-menu-modal.active {
            display: flex;
            opacity: 1;
        }

        .mobile-menu-content {
            background: white;
            width: 90%;
            max-width: 400px;
            border-radius: 16px;
            padding: 30px 24px;
            margin: auto;
            max-height: 90vh;
            overflow-y-auto;
            transform: scale(0.95);
            transition: transform 0.3s ease;
        }

        .mobile-menu-modal.active .mobile-menu-content {
            transform: scale(1);
        }

        .mobile-menu-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 24px;
            padding-bottom: 16px;
            border-bottom: 2px solid #f0f0f0;
        }

        .mobile-menu-header img {
            height: 50px;
            width: auto;
        }

        .close-mobile-menu {
            background: none;
            border: none;
            font-size: 28px;
            cursor: pointer;
            color: #002538;
            padding: 0;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .mobile-menu-section {
            margin-bottom: 24px;
        }

        .mobile-menu-title {
            font-size: 12px;
            font-weight: 700;
            color: #006e1d;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            margin-bottom: 12px;
            display: block;
        }

        .mobile-menu-links {
            list-style: none;
            padding: 0;
            margin: 0;
            display: flex;
            flex-direction: column;
            gap: 8px;
        }

        .mobile-menu-links li a {
            display: block;
            padding: 10px 12px;
            color: #111c2d;
            text-decoration: none;
            font-size: 14px;
            font-weight: 500;
            border-radius: 6px;
            transition: all 0.2s ease;
        }

        .mobile-menu-links li a:hover {
            background: #f0f0f0;
            color: #006e1d;
            padding-left: 16px;
        }

        .contact-item {
            display: flex;
            align-items: flex-start;
            gap: 12px;
            margin-bottom: 16px;
        }

        .contact-item .material-symbols-outlined {
            color: #006e1d;
            flex-shrink: 0;
            margin-top: 2px;
        }

        .contact-text {
            font-size: 13px;
            color: #41474d;
            line-height: 1.5;
        }

        .admission-btn-mobile {
            width: 100%;
            background: #006e1d;
            color: white;
            border: none;
            padding: 12px 16px;
            border-radius: 8px;
            font-weight: 700;
            font-size: 14px;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            cursor: pointer;
            transition: all 0.3s ease;
            margin-top: 16px;
        }

        .admission-btn-mobile:hover {
            background: #005314;
            box-shadow: 0 4px 12px rgba(0, 110, 29, 0.3);
        }
    </style>
</head>

<body class="bg-surface font-body-md text-on-surface overflow-x-hidden">
    <header class="fixed top-0 w-full z-50 bg-[#063B56]">
        <div class="flex justify-between items-center w-full px-4 lg:px-8 py-3 max-w-[1440px] mx-auto">
            <!-- Logo on the left -->
            <div class="flex items-center space-x-3">
                <img src="assets/logo.png" alt="">
            </div>
            <!-- White Pill Container for Navigation -->
            <div
                class="hidden xl:flex bg-white rounded-l-full py-3 px-10 items-center space-x-6 shadow-xl relative -mr-8">
                <nav
                    class="flex items-center space-x-6 font-['Plus_Jakarta_Sans'] font-bold text-[10px] tracking-wider uppercase text-black">
                    <a class="hover:text-[#063B56] transition-colors" href="#">Home</a>
                    <div class="dropdown-item relative">
                        <div class="flex items-center space-x-1 cursor-pointer hover:text-[#063B56]">
                            <span>About Us</span>
                            <span class="material-symbols-outlined text-xs">expand_more</span>
                        </div>
                        <div class="dropdown-menu shadow-lg">
                            <a href="#">School History</a>
                            <a href="#">Vision & Mission</a>
                            <a href="#">Leadership Team</a>
                            <a href="#">Awards & Recognition</a>
                        </div>
                    </div>
                    <div class="dropdown-item relative">
                        <div class="flex items-center space-x-1 cursor-pointer hover:text-[#063B56]">
                            <span>Management</span>
                            <span class="material-symbols-outlined text-xs">expand_more</span>
                        </div>
                        <div class="dropdown-menu shadow-lg">
                            <a href="#">Principal</a>
                            <a href="#">Correspondent</a>
                            <a href="#">Administrative Staff</a>
                            <a href="#">Governance</a>
                        </div>
                    </div>
                    <div class="dropdown-item relative">
                        <div class="flex items-center space-x-1 cursor-pointer hover:text-[#063B56]">
                            <span>Academics</span>
                            <span class="material-symbols-outlined text-xs">expand_more</span>
                        </div>
                        <div class="dropdown-menu shadow-lg">
                            <a href="#">Curriculum</a>
                            <a href="#">Faculty</a>
                            <a href="#">Student Results</a>
                            <a href="#">Study Materials</a>
                        </div>
                    </div>
                    <div class="dropdown-item relative">
                        <div class="flex items-center space-x-1 cursor-pointer hover:text-[#063B56]">
                            <span>Beyond Academics</span>
                            <span class="material-symbols-outlined text-xs">expand_more</span>
                        </div>
                        <div class="dropdown-menu shadow-lg">
                            <a href="#">Sports</a>
                            <a href="#">Cultural Activities</a>
                            <a href="#">Science & Tech Club</a>
                            <a href="#">Clubs & Societies</a>
                        </div>
                    </div>
                    <div class="dropdown-item relative">
                        <div class="flex items-center space-x-1 cursor-pointer hover:text-[#063B56]">
                            <span>Admission</span>
                            <span class="material-symbols-outlined text-xs">expand_more</span>
                        </div>
                        <div class="dropdown-menu shadow-lg">
                            <a href="#">Apply Now</a>
                            <a href="#">Admission Criteria</a>
                            <a href="#">Fee Structure</a>
                            <a href="#">Scholarship</a>
                        </div>
                    </div>
                    <div class="dropdown-item relative">
                        <div class="flex items-center space-x-1 cursor-pointer hover:text-[#063B56]">
                            <span>Campus</span>
                            <span class="material-symbols-outlined text-xs">expand_more</span>
                        </div>
                        <div class="dropdown-menu shadow-lg">
                            <a href="#">Infrastructure</a>
                            <a href="#">Labs & Facilities</a>
                            <a href="#">Library</a>
                            <a href="#">Sports Complex</a>
                        </div>
                    </div>
                    <div class="dropdown-item relative">
                        <div class="flex items-center space-x-1 cursor-pointer hover:text-[#063B56]">
                            <span>Community</span>
                            <span class="material-symbols-outlined text-xs">expand_more</span>
                        </div>
                        <div class="dropdown-menu shadow-lg">
                            <a href="#">Events</a>
                            <a href="#">Alumni Network</a>
                            <a href="#">Parent Portal</a>
                            <a href="#">Community Service</a>
                        </div>
                    </div>
                    <div class="dropdown-item relative">
                        <div class="flex items-center space-x-1 cursor-pointer hover:text-[#063B56]">
                            <span>Gallery</span>
                            <span class="material-symbols-outlined text-xs">expand_more</span>
                        </div>
                        <div class="dropdown-menu shadow-lg">
