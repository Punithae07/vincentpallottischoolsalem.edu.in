                    <li><a href="#">Contact Us</a></li>
                </ul>
            </div>

            <!-- Contact Details Section -->
            <div class="mobile-menu-section">
                <span class="mobile-menu-title">Contact Us</span>
                
                <div class="contact-item">
                    <span class="material-symbols-outlined text-lg">location_on</span>
                    <div class="contact-text">
                        123 Academic Way, Prestige City<br>
                        Salem, Tamil Nadu 636001<br>
                        India
                    </div>
                </div>
                
                <div class="contact-item">
                    <span class="material-symbols-outlined text-lg">phone</span>
                    <div class="contact-text">
                        +91 0427-2383970<br>
                        +91 0427-2383971
                    </div>
                </div>
                
                <div class="contact-item">
                    <span class="material-symbols-outlined text-lg">mail</span>
                    <div class="contact-text">
                        info@academicprestige.edu
                    </div>
                </div>
            </div>

            <!-- Admission Button -->
            <button class="admission-btn-mobile" id="admission-btn">Open Admission</button>
        </div>
    </div>
    <main>
        <!-- Hero Section -->
        <section class="relative h-[100vh] min-h-[600px] flex items-center overflow-hidden animate-gradient">
            <div class="absolute inset-0 z-0">
                <img alt="Modern school building and happy students"
                    class="w-full h-full object-cover scale-105 mix-blend-overlay opacity-40"
                    src="assets/slider01.jpg" />
                <div class="absolute inset-0 bg-gradient-to-r from-primary/95 via-primary/80 to-transparent"></div>
            </div>
            <div class="relative z-10 max-w-[1280px] mx-auto px-8 w-full mt-16">
                <div class="max-w-2xl text-white">
                    <span
                        class="inline-block bg-secondary px-4 py-1 rounded-full text-sm font-bold tracking-widest uppercase mb-6 shadow-lg">Established
                        1984</span>
                    <h1 class="font-h1 text-h1 mb-6 leading-tight drop-shadow-md">Empowering Minds, Shaping Global
                        Leaders</h1>
                    <p class="text-body-lg mb-8 opacity-90 leading-relaxed max-w-xl">Where tradition meets modern
                        pedagogy. Experience a transformative education that prepares students for the challenges of
                        tomorrow in our state-of-the-art facilities.</p>
                    <div class="flex flex-wrap gap-4">
                        <button
                            class="bg-secondary text-white px-10 py-4 rounded-full font-bold text-lg hover:shadow-xl hover:-translate-y-1 transition-all">Explore
                            Programs</button>
                        <button
                            class="border-2 border-white/50 text-white px-10 py-4 rounded-full font-bold text-lg hover:bg-white hover:text-primary transition-all backdrop-blur-sm">Campus
                            Tour</button>
                    </div>
                </div>
            </div>
            <div class="blob-bg w-[500px] h-[500px] bg-secondary -bottom-20 -right-20 animate-pulse"></div>
        </section>
        <!-- Feature Boxes -->
        <section class="py-20 bg-white relative z-20 -mt-16">
            <div class="max-w-[1280px] mx-auto px-8">
                <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
                    <div
                        class="p-10 bg-white rounded-6xl shadow-[0_20px_50px_rgba(8,0,42,0.08)] hover:-translate-y-2 transition-transform duration-300 group border border-slate-50">
                        <div
                            class="w-16 h-16 bg-secondary/10 rounded-full flex items-center justify-center mb-6 group-hover:bg-secondary transition-colors">
                            <img src="assets/about-icon.png" alt="">
                        </div>
                        <h3 class="font-h3 text-h3 text-primary mb-4">Activities</h3>
                        <p class="text-slate-600 mb-6 leading-relaxed">School conducts various activities for students
                            for their holistic development, from robotic labs to performing arts.</p>
                    </div>
                    <div
                        class="p-10 bg-white rounded-6xl shadow-[0_20px_50px_rgba(8,0,42,0.08)] hover:-translate-y-2 transition-transform duration-300 group border border-slate-50">
                        <div
                            class="w-16 h-16 bg-secondary/10 rounded-full flex items-center justify-center mb-6 group-hover:bg-secondary transition-colors">
                            <img src="assets/about-icon01.png" alt="">
                        </div>
                        <h3 class="font-h3 text-h3 text-primary mb-4">Events</h3>
                        <p class="text-slate-600 mb-6 leading-relaxed">The School has scheduled various events
                            throughout the year including Annual Day, Sports Meet and Cultural Fests.</p>
                    </div>
                    <div
                        class="p-10 bg-white rounded-6xl shadow-[0_20px_50px_rgba(8,0,42,0.08)] hover:-translate-y-2 transition-transform duration-300 group border border-slate-50">
                        <div
                            class="w-16 h-16 bg-secondary/10 rounded-full flex items-center justify-center mb-6 group-hover:bg-secondary transition-colors">
                            <img src="assets/about-icon02.png" alt="">                        </div>
                        <h3 class="font-h3 text-h3 text-primary mb-4">Achievements</h3>
                        <p class="text-slate-600 mb-6 leading-relaxed">The Management and staff members of our
                            institution are proud to convey our record of 100% academic excellence.</p>
                    </div>
                </div>
            </div>
        </section>
        <!-- About Section -->
        <section class="py-section-padding bg-white overflow-hidden">
            <div class="max-w-[1280px] mx-auto px-8 grid grid-cols-1 lg:grid-cols-2 gap-20 items-center">
                <div class="relative">
                    <div class="relative w-full aspect-square max-w-md mx-auto">
                        <div class="absolute inset-0 bg-secondary/5 rounded-full -m-4"></div>
                        <div
                            class="w-full h-full circular-mask border-8 border-white shadow-2xl relative z-10 overflow-hidden">
                            <img alt="Academic leadership and campus scenery" class="w-full h-full object-cover"
                                src="https://lh3.googleusercontent.com/aida-public/AB6AXuA1DyDq1caBeShXxrBib5WRDmaUXiHW5HUhMnWOKYNNFsn9ms0leIDNHL3xttiIQkl82XSdnyd6nYwRHo2tC_tCXujdbuXHW4rFvM5tBl12EGoVh_HNljGtdnf4xfwGk31T7lWkVTmESm1qsYy0cDjPHuyHSx8Nzp72lSsF_XyMtU5CCmz_OPmmy44w0kQHGPr2EyFsB8Aa0MDvOkxeCHsxxVpPhpQG63g4Zn-yqSQ2i_Owv2GXJZh3baCBbHDcFWeDlPkkTAPDGJQ" />
                        </div>
                        <!-- Decorative elements -->
                        <div
                            class="absolute -bottom-6 -left-6 bg-white p-4 rounded-xl shadow-lg z-20 flex items-center space-x-3">
                            <div class="bg-secondary p-2 rounded-full">
                                <span class="material-symbols-outlined text-white text-xl">workspace_premium</span>
                            </div>
                            <div>
                                <div class="font-bold text-primary leading-none">Top Rated</div>
                                <div class="text-[10px] text-slate-500 uppercase tracking-widest mt-1">Institutions 2024
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div>
                    <span class="text-slate-400 font-bold tracking-widest uppercase text-sm block mb-4">\\\ ABOUT SCHOOL
                        \\\</span>
                    <h2 class="font-h2 text-h2 text-primary mb-6">Who Are We?</h2>
                    <p class="text-body-md text-slate-600 mb-6">AcademicPrestige was founded in 1984 as a beacon of
                        learning. Situated on the Steel Plant Road, opposite to Govt. Medical College, the school is
                        just 12 km distance away from Salem town.</p>
                    <p class="text-body-md text-slate-600 mb-8">Managed by dedicated educators, the school seeks to
                        provide sound academics to its pupils, ensuring at the same time an opportunity to excel in
                        sports, co-curricular and extracurricular activities.</p>
                    <button
                        class="bg-secondary text-white px-8 py-3 rounded font-bold hover:bg-opacity-90 transition-all uppercase tracking-wider text-sm shadow-md">Read
                        More</button>
                </div>
            </div>
        </section>
        <!-- Notice Board Section -->
